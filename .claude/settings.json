{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx vitest *)",
      "Bash(git *)",
      "Bash(node scripts/*)",
      "Bash(mkdir -p *)",
      "Bash(ls *)"
    ],
    "deny": [
      "Bash(rm -rf node_modules)",
      "Bash(rm -rf .git)",
      "Bash(rm -rf /)",
      "Bash(format C:*)"
    ]
  }
}
